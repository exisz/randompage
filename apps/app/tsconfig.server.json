{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "outDir": "api-dist",
    "rootDir": "src",
    "declaration": false,
    "noEmit": false,
    "lib": ["ES2022"],
    "types": ["node"],
    "allowJs": false
  },
  "include": ["src/server/**/*"],
  "exclude": ["src/client/**/*", "src/server/generated/**/*"]
}
