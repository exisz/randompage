generator client {
  provider = "prisma-client-js"
  output   = "../src/server/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("LOCAL_DATABASE_URL")
}

model User {
  id          String   @id
  displayName String   @map("display_name")
  createdAt   DateTime @map("created_at")

  credentials         Credential[]
  sessions            Session[]
  pushSubscriptions   PushSubscription[]
  bookmarks           Bookmark[]
  bookmarkCollections BookmarkCollection[]
  pushHistory         PushHistory[]
  browsingEvents      BrowsingEvent[]
  userPreferences     UserPreference[]
  passageReviews      PassageReview[]
  passageAnnotations  PassageAnnotation[]

  @@map("users")
}

model Credential {
  id           String   @id
  userId       String   @map("user_id")
  credentialId String   @unique @map("credential_id")
  publicKey    String   @map("public_key")
  counter      Int      @default(0)
  createdAt    DateTime @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("credentials")
}

model Session {
  id        String   @id
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model Passage {
  id        String  @id
  text      String
  bookTitle String  @map("book_title")
  author    String
  chapter   String?
  tags      String
  language  String  @default("en")

  bookmarks      Bookmark[]
  pushHistory    PushHistory[]
  browsingEvents BrowsingEvent[]
  passageReviews PassageReview[]
  annotations    PassageAnnotation[]

  @@map("passages")
}

model Bookmark {
  id        String   @id
  userId    String   @map("user_id")
  passageId String   @map("passage_id")
  createdAt DateTime @map("created_at")
  note      String?  @map("note")
  userTags  String?  @map("user_tags")

  user            User                     @relation(fields: [userId], references: [id])
  passage         Passage                  @relation(fields: [passageId], references: [id])
  collectionItems BookmarkCollectionItem[]
  passageReviews  PassageReview[]
  annotations     PassageAnnotation[]

  @@map("bookmarks")
}

model BookmarkCollection {
  id        String   @id
  userId    String   @map("user_id")
  name      String
  purpose   String?
  createdAt DateTime @map("created_at")
  updatedAt DateTime @map("updated_at")

  user  User                     @relation(fields: [userId], references: [id])
  items BookmarkCollectionItem[]

  @@unique([userId, name])
  @@index([userId, updatedAt])
  @@map("bookmark_collections")
}

model BookmarkCollectionItem {
  id           String   @id
  collectionId String   @map("collection_id")
  bookmarkId   String   @map("bookmark_id")
  createdAt    DateTime @map("created_at")

  collection BookmarkCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  bookmark   Bookmark           @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)

  @@unique([collectionId, bookmarkId])
  @@index([bookmarkId])
  @@map("bookmark_collection_items")
}

model PushSubscription {
  id        String   @id
  userId    String   @map("user_id")
  endpoint  String
  p256dh    String
  auth      String
  createdAt DateTime @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("push_subscriptions")
}

model PushHistory {
  id        String    @id
  userId    String    @map("user_id")
  passageId String    @map("passage_id")
  sentAt    DateTime  @map("sent_at")
  readAt    DateTime? @map("read_at")

  user    User    @relation(fields: [userId], references: [id])
  passage Passage @relation(fields: [passageId], references: [id])

  @@map("push_history")
}

model BrowsingEvent {
  id        String   @id
  userId    String   @map("user_id")
  passageId String   @map("passage_id")
  action    String
  source    String   @default("discover")
  createdAt DateTime @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  passage Passage @relation(fields: [passageId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, passageId])
  @@map("browsing_events")
}

model UserPreference {
  id        String   @id
  userId    String   @map("user_id")
  tag       String
  weight    Int      @default(1)
  updatedAt DateTime @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("user_preferences")
}

model PassageReview {
  id         String   @id
  userId     String   @map("user_id")
  bookmarkId String   @map("bookmark_id")
  passageId  String   @map("passage_id")
  action     String
  reviewedAt DateTime @map("reviewed_at")
  dueAfter   DateTime @map("due_after")
  box        Int?

  user     User     @relation(fields: [userId], references: [id])
  bookmark Bookmark @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  passage  Passage  @relation(fields: [passageId], references: [id])

  @@index([userId, dueAfter])
  @@index([bookmarkId, reviewedAt])
  @@map("passage_reviews")
}

model PassageAnnotation {
  id          String   @id
  userId      String   @map("user_id")
  bookmarkId  String   @map("bookmark_id")
  passageId   String   @map("passage_id")
  quote       String
  startOffset Int      @map("start_offset")
  endOffset   Int      @map("end_offset")
  note        String
  userTags    String?  @map("user_tags")
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")

  user     User     @relation(fields: [userId], references: [id])
  bookmark Bookmark @relation(fields: [bookmarkId], references: [id], onDelete: Cascade)
  passage  Passage  @relation(fields: [passageId], references: [id])

  @@index([userId, bookmarkId])
  @@index([passageId])
  @@map("passage_annotations")
}
