# App (Vercel Project: randompage-app)
VITE_LOGTO_ENDPOINT=https://id.rollersoft.com.au
VITE_LOGTO_APP_ID=<logto-app-id>
VITE_LOGTO_API_RESOURCE=https://randompage.rollersoft.com.au/api
VITE_VAPID_PUBLIC_KEY=<vapid-public-key>

# Server (Vercel Project env vars)
LOGTO_ENDPOINT=https://id.rollersoft.com.au
LOGTO_API_RESOURCE=https://randompage.rollersoft.com.au/api
VAPID_PRIVATE_KEY=<vapid-private-key>
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<vapid-public-key>
CRON_SECRET=<cron-secret>

# Turso (injected by Vercel Turso integration)
TURSO_DATABASE_URL=libsql://...
TURSO_AUTH_TOKEN=...

# Local dev only
LOCAL_DATABASE_URL=file:./prisma/dev.db
