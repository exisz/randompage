<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.randompage.ingest-hot-books</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>cd /Users/c/repos/randompage &amp;&amp; /usr/bin/env node apps/app/scripts/ingest-hot-books.mjs --limit 10 --lang en,zh &gt;&gt; ~/Library/Logs/randompage-ingest.log 2&gt;&amp;1</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>3</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>
  <key>RunAtLoad</key>
  <false/>
  <key>StandardOutPath</key>
  <string>/Users/c/Library/Logs/randompage-ingest.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/c/Library/Logs/randompage-ingest.log</string>
</dict>
</plist>
