{
  "name": "@randompage/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "prisma generate && vite build && tsc -p tsconfig.server.json && node -e \"import('node:fs').then(fs=>{fs.cpSync('src/server/generated','api-dist/server/generated',{recursive:true,force:true});console.log('[build] copied prisma generated to api-dist')})\"",
    "preview": "vite preview",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "check:push-policy": "node scripts/check-push-selection-policy.mjs",
    "check:push-click-policy": "node scripts/check-push-click-attribution-policy.mjs",
    "check:browsing-events-policy": "node scripts/check-browsing-events-policy.mjs",
    "check:schema-mapping": "node scripts/check-schema-table-mapping.mjs",
    "check:tag-policy": "tsx scripts/check-tag-parsing-policy.ts",
    "android:sync": "capacitor sync android",
    "android:open": "capacitor open android",
    "android:apk:debug": "pnpm build && capacitor sync android && cd android && ./gradlew assembleDebug",
    "search:sources": "node scripts/search-source-candidates.mjs",
    "import:epub": "node scripts/import-epub.mjs",
    "check:passage-lengths": "node scripts/check-passage-length-policy.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@libsql/client": "^0.14.0",
    "@logto/browser": "^3.0.13",
    "@prisma/adapter-libsql": "^6.1.0",
    "@prisma/client": "^6.1.0",
    "@vercel/node": "^5.0.0",
    "cheerio": "^1.2.0",
    "express": "^4.21.0",
    "fast-xml-parser": "^5.8.0",
    "jose": "^5.9.0",
    "jszip": "^3.10.1",
    "nanoid": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "vite-express": "^0.21.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-push": "^3.6.3",
    "@vitejs/plugin-react": "^4.3.0",
    "daisyui": "^5.0.0",
    "dotenv": "^16.4.5",
    "prisma": "^6.1.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
