---
import '../../styles/global.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Blog — RandomPage" description="架构笔记 / 踩坑记录 / 使用说明">
  <h1 class="text-4xl font-bold mb-8">Blog</h1>
  <div class="space-y-4">
    {posts.map(post => (
      <a href={`/blog/${post.id}`} class="card bg-base-200 hover:bg-base-300 transition-colors">
        <div class="card-body">
          <h2 class="card-title">{post.data.title}</h2>
          <p class="opacity-80 text-sm">{post.data.description}</p>
          <div class="flex gap-2 items-center text-xs opacity-60 mt-2">
            <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
            <div class="flex gap-1 ml-2">
              {post.data.tags.map(t => <span class="badge badge-outline badge-xs">{t}</span>)}
            </div>
          </div>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
