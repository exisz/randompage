{
  "name": "randompage",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev:landing": "pnpm --filter landing dev",
    "dev:app": "pnpm --filter @randompage/app dev",
    "build:landing": "pnpm --filter landing build",
    "build:app": "pnpm --filter @randompage/app build",
    "db:generate": "pnpm --filter @randompage/app exec prisma generate",
    "db:push-remote": "pnpm --filter @randompage/app exec node ../../scripts/db-push-remote.mjs"
  }
}
